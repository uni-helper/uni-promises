    "@commitlint/config-conventional": "^20.5.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.3",
    "@vscode/vsce": "^3.9.1",
    "bumpp": "^11.1.0",
    "concurrently": "^9.2.1",
    "is-ci": "^4.1.0",
    "lefthook": "^2.1.6",
    "ovsx": "^0.10.11",
    "simple-git": "^3.36.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "ultracite": "^7.6.4",
    "vue": "~3.4.38"
